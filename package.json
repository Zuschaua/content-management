{
  "name": "content-factory",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @content-factory/api db:migrate",
    "db:generate": "pnpm --filter @content-factory/api db:generate",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "docker:build": "docker compose build"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["argon2", "esbuild", "msgpackr-extract", "sharp", "unrs-resolver"]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "eslint": "^9.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0"
  }
}
