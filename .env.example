# Database
POSTGRES_USER=contentfactory
POSTGRES_PASSWORD=contentfactory
POSTGRES_DB=contentfactory
POSTGRES_PORT=5432
DATABASE_URL=postgres://contentfactory:contentfactory@localhost:5432/contentfactory

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_BUCKET=content-factory
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API
API_PORT=3001
PORT=3001

# Frontend
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Security — CHANGE IN PRODUCTION
ENCRYPTION_KEY=generate-a-32-byte-hex-key-for-production
